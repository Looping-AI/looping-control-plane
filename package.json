{
  "type": "module",
  "scripts": {
    "dev:setup": "bun run scripts/dev-setup.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && bun run lint:lintoko && bun run lint:moc",
    "lint:lintoko": "$(mops toolchain bin lintoko) -r .lintoko src tests",
    "lint:moc": "bun run scripts/lint-motoko.ts",
    "postinstall": "husky",
    "test:build": "bun run tests/build.ts",
    "test:mops": "mops test",
    "test:unit:tools": "bun test tests/unit-tests/control-plane-core/tools",
    "test:unit:not-tools": "bun test tests/unit-tests/control-plane-core/agents tests/unit-tests/control-plane-core/events tests/unit-tests/control-plane-core/instructions tests/unit-tests/control-plane-core/middleware tests/unit-tests/control-plane-core/models tests/unit-tests/control-plane-core/services tests/unit-tests/control-plane-core/timers tests/unit-tests/control-plane-core/utilities tests/unit-tests/control-plane-core/wrappers",
    "test:integration": "bun test tests/integration-tests",
    "test:ts-parallel": "bun run scripts/run-parallel-tests.ts",
    "test": "bun run test:build && bun run test:mops && bun run test:ts-parallel"
  },
  "devDependencies": {
    "@dfinity/pic": "^0.21.0",
    "@types/bun": "^1.3.12",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "prettier-plugin-motoko": "^0.13.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "trustedDependencies": [
    "@dfinity/pic"
  ]
}
