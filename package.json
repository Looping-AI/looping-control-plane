{
  "type": "module",
  "scripts": {
    "dev:setup": "bun run scripts/dev-setup.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && lintoko -r .lintoko src tests",
    "postinstall": "husky",
    "test:build": "bun run tests/build.ts",
    "test:mops": "mops test",
    "test:unit:tools": "bun test tests/unit-tests/control-plane-core/tools",
    "test:unit:not-tools": "bun test tests/unit-tests --ignore=tests/unit-tests/control-plane-core/tools",
    "test:integration": "bun test tests/integration-tests",
    "test": "bun run test:build && bun run test:mops && bun run test:integration && bun run test:unit:tools && bun run test:unit:not-tools"
  },
  "dependencies": {
    "@icp-sdk/core": "^5.0.0"
  },
  "devDependencies": {
    "@dfinity/pic": "^0.20.0",
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier-plugin-motoko": "^0.13.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "trustedDependencies": [
    "@dfinity/pic"
  ]
}
