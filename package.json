{
  "type": "module",
  "scripts": {
    "dev:setup": "bun run scripts/dev-setup.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && lintoko -r .lintoko src tests",
    "postinstall": "husky",
    "test:build": "bun run tests/build.ts",
    "test:mops": "mops test",
    "test:unit:tools": "bun test tests/unit-tests/control-plane-core/tools",
    "test:unit:not-tools": "bun test tests/unit-tests --ignore=tests/unit-tests/control-plane-core/tools",
    "test:integration": "bun test tests/integration-tests",
    "test:ts-parallel": "bun run scripts/run-parallel-tests.ts",
    "test": "bun run test:build && bun run test:mops && bun run test:ts-parallel"
  },
  "dependencies": {
    "@icp-sdk/core": "^5.2.1"
  },
  "devDependencies": {
    "@dfinity/pic": "^0.21.0",
    "@types/bun": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier-plugin-motoko": "^0.13.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "trustedDependencies": [
    "@dfinity/pic"
  ]
}
