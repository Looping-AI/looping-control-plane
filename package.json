{
  "type": "module",
  "scripts": {
    "dev:setup": "bun run scripts/dev-setup.ts",
    "staging:reinstall": "bun run scripts/staging-reinstall.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint . && bun run lint:lintoko && bun run lint:moc",
    "lint:lintoko": "$(mops toolchain bin lintoko) -r .lintoko src tests",
    "lint:moc": "bun run scripts/lint-motoko.ts",
    "postinstall": "husky",
    "test:build": "bun run tests/build.ts",
    "test:mops": "mops test",
    "test:control-plane-core": "bun test tests/control-plane-core",
    "test:internal-engine": "bun test tests/internal-engine",
    "test:ts-parallel": "bun run scripts/run-parallel-tests.ts",
    "test": "bun run test:build && bun run test:mops && bun run test:ts-parallel"
  },
  "devDependencies": {
    "@dfinity/pic": "^0.21.0",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "prettier-plugin-motoko": "^0.13.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "trustedDependencies": [
    "@dfinity/pic"
  ]
}
